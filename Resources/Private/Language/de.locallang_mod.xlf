			<trans-unit id="error.analysis_failed" resname="error.analysis_failed">
				<source>Analysis failed. Check console for details.</source>
				<target>Analyse fehlgeschlagen. Details finden Sie in der Konsole.</target>
			</trans-unit>
			<trans-unit id="error.timeout" resname="error.timeout">
				<source>Audit took too long; showing partial results. Some metrics (like INP) might be missing.</source>
