			</trans-unit>
			<trans-unit id="error.access_denied" resname="error.access_denied">
				<source>Could not access the page (CSP or Cross-Origin restriction). Ensure the page allows script injection.</source>
				<target>Zugriff auf die Seite verweigert (CSP oder Cross-Origin Restriktion). Bitte stellen Sie sicher, dass die Seite Skript-Injektionen erlaubt.</target>
			</trans-unit>
			<trans-unit id="error.network" resname="error.network">
				<source>Unable to synchronize results with the server. Please check your connection.</source>
				<target>Synchronisierung mit dem Server fehlgeschlagen. Bitte prüfen Sie Ihre Verbindung.</target>
			</trans-unit>
			<trans-unit id="button.close" resname="button.close">
